PORT=5000
NODE_ENV=development

# App
# CORS - production origins are hardcoded in app.js
# This variable is no longer used for origin control
# ALLOWED_ORIGINS=https://curevie.net
APP_BASE_URL=https://yourdomain.com/api/v1
CLOSE_REQUEST_PDF_TIMEOUT_MS=20000

# Prefer DATABASE_URL. If omitted, DB_HOST/DB_PORT/DB_USER/DB_PASSWORD/DB_NAME will be used.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/curevie
DB_SSL=false

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=curevie
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-strong-secret
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_EXPIRES_IN=15m

DEFAULT_ADMIN_EMAIL=admin@medical.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_PROVIDER_NAME=Default Provider
DEFAULT_PROVIDER_EMAIL=provider@medical.com
DEFAULT_PROVIDER_PASSWORD=Provider123!
DEFAULT_PROVIDER_PHONE=
DEFAULT_PROVIDER_TYPE=DOCTOR

BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_API_KEY=your-api-key
BUNNY_CDN_URL=https://your-pullzone.b-cdn.net
BUNNY_STORAGE_REGION=de

# LibreOffice
LIBREOFFICE_PATH=soffice

# PDF Fonts (optional — leave empty to use system defaults)
PDF_FONT_REGULAR_PATH=
PDF_FONT_BOLD_PATH=
PDF_FONT_ARABIC_PATH=
PDF_FONT_ARABIC_BOLD_PATH=
