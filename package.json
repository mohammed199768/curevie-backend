{
  "name": "curevie-backend",
  "version": "1.0.0",
  "description": "Medical platform middleware backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --ignore 'uploads/' --ignore 'qa_artifacts/' --ignore 'logs/' --ignore '*.pdf' --ignore '*.log' server.js",
    "db:init": "node config/initDb.js",
    "db:migrate": "node config/runMigrations.js",
    "db:reset:clinical-catalog": "node config/seeds/reset_clinical_catalog.js",
    "db:seed:ranges": "node config/seeds/lab_ranges_seed.js",
    "db:seed:lab-catalog:psap": "node config/seeds/psap_lab_catalog_seed.js",
    "db:seed:provider": "node config/seeds/provider_seed.js"
  },
  "dependencies": {
    "@pdf-lib/fontkit": "^1.1.1",
    "axios": "^1.13.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "file-type": "^16.5.4",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pdf-lib": "^1.17.1",
    "pg": "^8.12.0",
    "puppeteer": "^24.39.1",
    "rate-limit-redis": "^4.3.1",
    "sharp": "^0.34.5",
    "winston": "^3.14.2",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
