const { Client } = require('pg'); const client = new Client({ user: 'postgres', password: process.env.DB_PASSWORD, host: 'localhost', database: 'curevie', port: 5432 }); client.connect().then(() => client.query(INSERT INTO service_requests (request_type, guest_name, guest_phone, guest_address, service_type, service_id) VALUES ('GUEST', 'T', '0', 'A', 'MEDICAL', '0cedcb0e-7c15-4ba8-bb41-0ca29f9e776e'))).catch(e => console.error(e.detail || e.message)).finally(() => client.end());
